{
  "info": {
    "name": "Controle Financeiro - TCC",
    "description": "Coleção para testar a API do Controle Financeiro. Rode na ordem: 1) Registrar OU 2) Login (salvam o token em {{token}}) -> demais requisições. As que precisam de id usam {{categoriaId}} / {{transacaoId}}, preenchidos automaticamente por scripts de teste.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "categoriaId", "value": "" },
    { "key": "transacaoId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Health (publico)",
      "request": {
        "method": "GET", "header": [],
        "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] }
      }
    },
    {
      "name": "2. Registrar (publico)",
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "if (pm.response.code === 201 || pm.response.code === 200) {",
        "  pm.collectionVariables.set('token', pm.response.json().accessToken);",
        "}"
      ] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Maria Teste\",\n  \"email\": \"maria@teste.com\",\n  \"senha\": \"123456\",\n  \"rendaMensal\": 3000.00\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/auth/registro", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "registro"] }
      }
    },
    {
      "name": "3. Login (publico)",
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 200', function () { pm.response.to.have.status(200); });",
        "pm.collectionVariables.set('token', pm.response.json().accessToken);"
      ] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"maria@teste.com\",\n  \"senha\": \"123456\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
      }
    },
    {
      "name": "4. Perfil (protegido)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/usuarios/perfil", "host": ["{{baseUrl}}"], "path": ["api", "v1", "usuarios", "perfil"] }
      }
    },
    {
      "name": "5. Atualizar perfil / renda (protegido)",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
        "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Maria Teste\",\n  \"rendaMensal\": 3500.00\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/usuarios/perfil", "host": ["{{baseUrl}}"], "path": ["api", "v1", "usuarios", "perfil"] }
      }
    },
    {
      "name": "6. Trocar senha (protegido)",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
        "body": { "mode": "raw", "raw": "{\n  \"senhaAtual\": \"123456\",\n  \"novaSenha\": \"novaSenha789\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/usuarios/senha", "host": ["{{baseUrl}}"], "path": ["api", "v1", "usuarios", "senha"] }
      }
    },
    {
      "name": "7. Listar categorias (protegido)",
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "const arr = pm.response.json();",
        "if (Array.isArray(arr) && arr.length > 0) { pm.collectionVariables.set('categoriaId', arr[0].id); }"
      ] } }],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/categorias", "host": ["{{baseUrl}}"], "path": ["api", "v1", "categorias"] }
      }
    },
    {
      "name": "8. Criar categoria (protegido)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
        "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Educacao\",\n  \"icone\": \"book\",\n  \"cor\": \"#2563EB\",\n  \"tipo\": \"DESPESA\",\n  \"orcamento\": 500.00,\n  \"descricao\": \"Cursos e livros\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/categorias", "host": ["{{baseUrl}}"], "path": ["api", "v1", "categorias"] }
      }
    },
    {
      "name": "9. Editar categoria (protegido)",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
        "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Educacao e Cursos\",\n  \"icone\": \"book\",\n  \"cor\": \"#1D4ED8\",\n  \"tipo\": \"DESPESA\",\n  \"orcamento\": 800.00,\n  \"descricao\": \"Atualizada\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/categorias/{{categoriaId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "categorias", "{{categoriaId}}"] }
      }
    },
    {
      "name": "10. Excluir categoria (protegido)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/categorias/{{categoriaId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "categorias", "{{categoriaId}}"] }
      }
    },
    {
      "name": "11. Listar transacoes (protegido, paginado)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/transacoes?page=0&size=20", "host": ["{{baseUrl}}"], "path": ["api", "v1", "transacoes"], "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "20" }] }
      }
    },
    {
      "name": "12. Criar transacao / gasto (protegido)",
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "if (pm.response.code === 201) { pm.collectionVariables.set('transacaoId', pm.response.json().id); }"
      ] } }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
        "body": { "mode": "raw", "raw": "{\n  \"tipo\": \"DESPESA\",\n  \"valor\": 89.90,\n  \"descricao\": \"Mercado\",\n  \"dataTransacao\": \"2026-06-12\",\n  \"categoriaId\": \"{{categoriaId}}\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/transacoes", "host": ["{{baseUrl}}"], "path": ["api", "v1", "transacoes"] }
      }
    },
    {
      "name": "13. Editar transacao (protegido)",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
        "body": { "mode": "raw", "raw": "{\n  \"tipo\": \"DESPESA\",\n  \"valor\": 99.90,\n  \"descricao\": \"Mercado (corrigido)\",\n  \"dataTransacao\": \"2026-06-12\",\n  \"categoriaId\": \"{{categoriaId}}\"\n}" },
        "url": { "raw": "{{baseUrl}}/api/v1/transacoes/{{transacaoId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "transacoes", "{{transacaoId}}"] }
      }
    },
    {
      "name": "14. Excluir transacao (protegido)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/transacoes/{{transacaoId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "transacoes", "{{transacaoId}}"] }
      }
    },
    {
      "name": "15. Dashboard (protegido)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/dashboard?periodo=2026-06", "host": ["{{baseUrl}}"], "path": ["api", "v1", "dashboard"], "query": [{ "key": "periodo", "value": "2026-06" }] }
      }
    },
    {
      "name": "16. Renda mensal - status (protegido)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/renda-mensal/status", "host": ["{{baseUrl}}"], "path": ["api", "renda-mensal", "status"] }
      }
    },
    {
      "name": "17. Renda mensal - executar (protegido)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/renda-mensal/executar", "host": ["{{baseUrl}}"], "path": ["api", "renda-mensal", "executar"] }
      }
    },
    {
      "name": "18. SEM TOKEN (deve dar 401)",
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('bloqueado sem token (401)', function () { pm.response.to.have.status(401); });"
      ] } }],
      "request": {
        "method": "GET", "header": [],
        "url": { "raw": "{{baseUrl}}/api/v1/transacoes", "host": ["{{baseUrl}}"], "path": ["api", "v1", "transacoes"] }
      }
    }
  ]
}
